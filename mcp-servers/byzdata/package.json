{
  "name": "@dxheroes/mcp-byzdata",
  "version": "1.0.0",
  "description": "Czech business registry MCP - ARES, Justice.cz, ISIR data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "mcpPackage": true,
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "local-mcp-gateway",
    "czech",
    "business",
    "registry",
    "ares"
  ],
  "author": "DX Heroes",
  "license": "MIT",
  "peerDependencies": {
    "@dxheroes/local-mcp-core": "workspace:*"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
