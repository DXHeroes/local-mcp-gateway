{
  "name": "@dxheroes/mcp-abra-flexi",
  "version": "0.3.3",
  "description": "MCP server for Abra Flexi REST API — invoices, contacts, products, and accounting for Czech businesses",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "mcpPackage": true,
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "local-mcp-gateway",
    "abra",
    "flexi",
    "flexibee",
    "erp",
    "czech",
    "accounting",
    "invoicing"
  ],
  "author": "DX Heroes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DXHeroes/local-mcp-gateway.git",
    "directory": "mcp-servers/abra-flexi"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@dxheroes/local-mcp-core": "workspace:*"
  },
  "dependencies": {
    "zod": "4.3.5"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
